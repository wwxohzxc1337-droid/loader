local guiInstance = nil
local guiVisible = true
local guiHotkey = Enum.KeyCode.Z 


function MainModule.SetGUIHotkey(keyCode)
    guiHotkey = keyCode
    MainModule.ShowNotification("GUI Hotkey", "Changed to: " .. tostring(keyCode), 2)
end

function MainModule.GetGUIHotkey()
    return guiHotkey
end

local function UpdateGUIVisibility()
    if not guiInstance then

        guiInstance = game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui"):FindFirstChild("MoroLiquid_Final")
    end
    
    if guiInstance then
        guiVisible = not guiVisible
        guiInstance.Enabled = guiVisible
        
        MainModule.ShowNotification("GUI", guiVisible and "Opened" or "Closed", 1)
    end
end

task.spawn(function()
    task.wait(1)
    
    guiInstance = game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui"):FindFirstChild("MoroLiquid_Final")
    
    if guiInstance then
        guiVisible = guiInstance.Enabled
        
        local inputService = game:GetService("UserInputService")
        
        inputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            
            if input.KeyCode == guiHotkey then
                UpdateGUIVisibility()
            end
        end)
        
        MainModule.ShowNotification("GUI Hotkey", "Press " .. tostring(guiHotkey) .. " to toggle", 3)
    else

        local playerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
        local descendantAddedConn
        
        descendantAddedConn = playerGui.DescendantAdded:Connect(function(descendant)
            if descendant.Name == "MoroLiquid_Final" and descendant:IsA("ScreenGui") then
                guiInstance = descendant
                guiVisible = guiInstance.Enabled
                

                local inputService = game:GetService("UserInputService")
                inputService.InputBegan:Connect(function(input, gameProcessed)
                    if gameProcessed then return end
                    if input.KeyCode == guiHotkey then
                        UpdateGUIVisibility()
                    end
                end)
                
                MainModule.ShowNotification("GUI Hotkey", "Press " .. tostring(guiHotkey) .. " to toggle", 3)
                descendantAddedConn:Disconnect()
            end
        end)
    end
end)


function MainModule.QuickSetGUIHotkey()QC
    MainModule.ShowNotification("Hotkey", "Press any key...", 3)
    
    local conn
    conn = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Keyboard then
            conn:Disconnect()
            MainModule.SetGUIHotkey(input.KeyCode)
            MainModule.ShowNotification("Hotkey", "Set to: " .. tostring(input.KeyCode), 2)
        end
    end)
    

    task.wait(5)
    if conn then
        conn:Disconnect()
    end
end
