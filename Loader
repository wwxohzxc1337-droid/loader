                setPromptInstant(obj)
            end
        end
        
        MainModule.NoCooldownProximitySettings.Connection = Workspace.DescendantAdded:Connect(function(obj)
            if obj:IsA("ProximityPrompt") then
                setPromptInstant(obj)
            end
        end)
        
    else
